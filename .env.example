# Copy to .env and fill in. All of these have free tiers.

# Supabase: Settings -> Database -> Connection string (use the session pooler URI)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# the-odds-api.com — free 500 credits/month
ODDS_API_KEY=

# LLM for Module 5: groq | gemini | ollama
LLM_PROVIDER=groq
GROQ_API_KEY=
GEMINI_API_KEY=
OLLAMA_MODEL=llama3.1:8b
